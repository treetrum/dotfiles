# use block cursor
shell-integration-features = no-cursor, ssh-terminfo, ssh-env
cursor-style = block

# theme
theme = TokyoNight Moon
window-width = 120
window-height = 32
background-opacity = 0.95
background-blur = 20
adjust-cell-height = 5%

# typography
font-size = 12
font-thicken = true
font-thicken-strength = 100

# Use Option key as Alt/Meta for terminal applications
macos-option-as-alt = true

# send alt-j as plain (alt-k is used by tmux for clearing screen)
keybind = alt+j=esc:j

# send shift-enter as a newline with CSI-u encoding
keybind = shift+enter=text:\x1b[13;2u

# Fix codex not respecting alt-backspace
keybind = alt+backspace=text:\x1b\x7f